generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int             @id @default(autoincrement())
  fullName           String
  phoneNumber        String          @unique
  passwordHash       String
  role               Role            @default(CLIENT)
  isVerified         Boolean         @default(false)
  workplaceSalonId   Int?
  createdAt          DateTime        @default(now())
  appointmentsBarber Appointment[]   @relation("BarberAppointments")
  appointmentsClient Appointment[]   @relation("ClientAppointments")
  favoriteSalons     FavoriteSalon[]
  orders             Order[]
  profile            Profile?
  reviews            Review[]
  salonsOwned        Salon[]         @relation("PatronSalons")
  workplaceSalon     Salon?          @relation("SalonEmployees", fields: [workplaceSalonId], references: [id])
}

model Profile {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique
  email                    String?
  avatarUrl                String?
  bio                      String?
  description              String?
  specialityTitle          String?
  fcmToken                 String?
  pushNotificationsEnabled Boolean  @default(true)
  darkModeEnabled          Boolean  @default(false)
  address                  String?
  latitude                 Float?
  longitude                Float?
  createdAt                DateTime @default(now())
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Salon {
  id             Int               @id @default(autoincrement())
  patronId       Int
  name           String
  description    String?
  contactPhone   String?
  address        String?
  latitude       Float?
  longitude      Float?
  googleMapsUrl  String?
  websiteUrl     String?
  coverImageUrl  String?
  speciality     String?
  rating         Float?
  approvalStatus ApprovalStatus    @default(PENDING)
  isForceClosed  Boolean           @default(false)
  createdAt      DateTime          @default(now())
  appointments   Appointment[]
  favoritedBy    FavoriteSalon[]
  orders         Order[]
  portfolio      PortfolioImage[]
  products       Product[]
  reviews        Review[]
  patron         User              @relation("PatronSalons", fields: [patronId], references: [id])
  socialLinks    SalonSocialLink[]
  services       Service[]
  employees      User[]            @relation("SalonEmployees")
  workingHours   WorkingHours[]
}

model WorkingHours {
  id        Int     @id @default(autoincrement())
  salonId   Int
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isDayOff  Boolean @default(false)
  salon     Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model SalonSocialLink {
  id       Int    @id @default(autoincrement())
  salonId  Int
  platform String
  url      String
  salon    Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model PortfolioImage {
  id        Int      @id @default(autoincrement())
  salonId   Int
  imageUrl  String
  createdAt DateTime @default(now())
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Service {
  id                  Int                  @id @default(autoincrement())
  salonId             Int
  name                String
  description         String?
  price               Float
  durationMinutes     Int
  imageUrl            String?
  appointmentServices AppointmentService[]
  salon               Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                    Int                  @id @default(autoincrement())
  clientId              Int
  salonId               Int
  barberId              Int?
  appointmentDate       DateTime
  estimatedEndTime      DateTime
  totalPrice            Float
  totalDurationMinutes  Int
  status                AppointmentStatus    @default(PENDING)
  is1hReminderSent      Boolean              @default(false)
  is10mReminderSent     Boolean              @default(false)
  lastCompletionAskTime DateTime?
  createdAt             DateTime             @default(now())
  barber                User?                @relation("BarberAppointments", fields: [barberId], references: [id])
  client                User                 @relation("ClientAppointments", fields: [clientId], references: [id])
  salon                 Salon                @relation(fields: [salonId], references: [id])
  services              AppointmentService[]
  review                Review?
}

model AppointmentService {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Review {
  id            Int         @id @default(autoincrement())
  clientId      Int
  salonId       Int
  appointmentId Int         @unique
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  client        User        @relation(fields: [clientId], references: [id])
  salon         Salon       @relation(fields: [salonId], references: [id])
}

model FavoriteSalon {
  id        Int      @id @default(autoincrement())
  clientId  Int
  salonId   Int
  createdAt DateTime @default(now())
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Product {
  id          Int         @id @default(autoincrement())
  salonId     Int
  name        String
  description String?
  price       Float
  stock       Int         @default(0)
  imageUrl    String?
  orderItems  OrderItem[]
  salon       Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Order {
  id          Int         @id @default(autoincrement())
  clientId    Int
  salonId     Int
  totalAmount Float
  status      String      @default("PENDING")
  createdAt   DateTime    @default(now())
  client      User        @relation(fields: [clientId], references: [id])
  salon       Salon       @relation(fields: [salonId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

enum Role {
  CLIENT
  PATRON
  EMPLOYEE
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  COMPLETED
  CANCELLED
  DECLINED
}

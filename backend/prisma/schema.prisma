generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS (الخيارات الثابتة)
// ==========================================
enum Role {
  CLIENT
  PATRON
  EMPLOYEE
  ADMIN
}

// Removed Tier enum as requested

enum ApprovalStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  COMPLETED
  CANCELLED
  DECLINED
}

// ==========================================
// MODELS (الجداول)
// ==========================================

model User {
  id               Int      @id @default(autoincrement())
  fullName         String
  phoneNumber      String   @unique
  passwordHash     String
  role             Role     @default(CLIENT)
  isVerified       Boolean  @default(false)
  workplaceSalonId Int? // كان صانع، هذي الصالة اللي يخدم فيها
  createdAt        DateTime @default(now())

  // Relations (الروابط)
  profile            Profile?
  salonsOwned        Salon[]         @relation("PatronSalons")
  workplaceSalon     Salon?          @relation("SalonEmployees", fields: [workplaceSalonId], references: [id])
  appointmentsClient Appointment[]   @relation("ClientAppointments")
  appointmentsBarber Appointment[]   @relation("BarberAppointments")
  reviews            Review[]
  favoriteSalons     FavoriteSalon[]
  orders             Order[]
}

model Profile {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email                    String?
  avatarUrl                String?
  bio                      String?
  description              String?
  specialityTitle          String?
  fcmToken                 String?
  pushNotificationsEnabled Boolean  @default(true)
  darkModeEnabled          Boolean  @default(false)
  address                  String?
  latitude                 Float?
  longitude                Float?
  createdAt                DateTime @default(now())
}

model OtpCode {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Salon {
  id             Int            @id @default(autoincrement())
  patronId       Int
  patron         User           @relation("PatronSalons", fields: [patronId], references: [id])
  name           String
  description    String?
  contactPhone   String?
  address        String?
  latitude       Float?
  longitude      Float?
  googleMapsUrl  String?
  websiteUrl     String?
  coverImageUrl  String?
  speciality     String? // NEW: Salon's main speciality
  rating         Float?  // Random initial rating
  approvalStatus ApprovalStatus @default(PENDING)
  isForceClosed  Boolean        @default(false)
  createdAt      DateTime       @default(now())

  // Relations
  employees    User[]            @relation("SalonEmployees")
  workingHours WorkingHours[]
  socialLinks  SalonSocialLink[]
  portfolio    PortfolioImage[]
  services     Service[]
  appointments Appointment[]
  reviews      Review[]
  favoritedBy  FavoriteSalon[]
  products     Product[]
  orders       Order[]
}

model WorkingHours {
  id        Int     @id @default(autoincrement())
  salonId   Int
  salon     Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 1 = Lundi, 7 = Dimanche
  openTime  String? // نجمو نخبيوها String "08:00"
  closeTime String?
  isDayOff  Boolean @default(false)
}

model SalonSocialLink {
  id       Int    @id @default(autoincrement())
  salonId  Int
  salon    Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  platform String
  url      String
}

model PortfolioImage {
  id        Int      @id @default(autoincrement())
  salonId   Int
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  imageUrl  String
  createdAt DateTime @default(now())
}

model Service {
  id                  Int                  @id @default(autoincrement())
  salonId             Int
  salon               Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  price               Float
  durationMinutes     Int
  imageUrl            String?
  appointmentServices AppointmentService[]
}

model Appointment {
  id       Int   @id @default(autoincrement())
  clientId Int
  client   User  @relation("ClientAppointments", fields: [clientId], references: [id])
  salonId  Int
  salon    Salon @relation(fields: [salonId], references: [id])
  barberId Int?
  barber   User? @relation("BarberAppointments", fields: [barberId], references: [id])

  appointmentDate      DateTime
  estimatedEndTime     DateTime
  totalPrice           Float
  totalDurationMinutes Int
  status               AppointmentStatus @default(PENDING)

  is1hReminderSent      Boolean   @default(false)
  is10mReminderSent     Boolean   @default(false)
  lastCompletionAskTime DateTime?
  createdAt             DateTime  @default(now())

  // Relations
  services AppointmentService[]
  review   Review?
}

model AppointmentService {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     Int
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Review {
  id            Int         @id @default(autoincrement())
  clientId      Int
  client        User        @relation(fields: [clientId], references: [id])
  salonId       Int
  salon         Salon       @relation(fields: [salonId], references: [id])
  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
}

model FavoriteSalon {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salonId   Int
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Product {
  id          Int         @id @default(autoincrement())
  salonId     Int
  salon       Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  stock       Int         @default(0)
  imageUrl    String?
  orderItems  OrderItem[]
}

model Order {
  id          Int         @id @default(autoincrement())
  clientId    Int
  client      User        @relation(fields: [clientId], references: [id])
  salonId     Int
  salon       Salon       @relation(fields: [salonId], references: [id])
  totalAmount Float
  status      String      @default("PENDING")
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}
